{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CheckupRequestPayload",
  "description": "A user- or router-requested Nurse checkup of harness integrity.",
  "type": "object",
  "required": [
    "checkup_id",
    "trigger_source",
    "trigger_reason",
    "scope",
    "checks_requested",
    "requested_by",
    "cooldown_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "checkup_id": { "type": "string" },
    "trigger_source": { "type": "string", "enum": ["user", "router", "security"] },
    "trigger_reason": { "type": "string" },
    "scope": {
      "type": "array",
      "items": { "type": "string", "enum": ["roles", "graph", "schemas", "config", "validator", "dox", "docs", "state-machine", "runtime-signals", "all"] },
      "minItems": 1
    },
    "checks_requested": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requested_by": { "type": "string" },
    "cooldown_policy": {
      "type": "object",
      "required": ["respect_cooldown", "override_reason"],
      "additionalProperties": false,
      "properties": {
        "respect_cooldown": { "type": "boolean" },
        "override_reason": { "type": "string" }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}