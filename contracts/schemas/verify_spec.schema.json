{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifySpecPayload",
  "description": "QC's request for a sandboxed, read-only check by the Verifier.",
  "type": "object",
  "required": [
    "verify_id",
    "target_ref",
    "check"
  ],
  "additionalProperties": false,
  "properties": {
    "verify_id": {
      "type": "string"
    },
    "target_ref": {
      "type": "string"
    },
    "check": {
      "type": "string"
    },
    "expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
