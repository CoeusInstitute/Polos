{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EpisodePayload",
  "description": "A structured record of one completed task or loop, derived from the audit log into the experience/ store. The dataset the Evaluator shadow-tests against and the Learning agent mines.",
  "type": "object",
  "required": [
    "episode_id",
    "trace_id",
    "result_status"
  ],
  "additionalProperties": false,
  "properties": {
    "episode_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "intent_ref": {
      "type": "string"
    },
    "plan": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gate_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result_status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed",
        "halted"
      ]
    }
  }
}
