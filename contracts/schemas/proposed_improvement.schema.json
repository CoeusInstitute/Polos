{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProposedImprovementPayload",
  "description": "A measured, evidence-backed improvement proposal. Must pass the Evaluator's shadow test before it can reach ratification.",
  "type": "object",
  "required": [
    "target_failure",
    "hypothesis",
    "kind",
    "target_role",
    "delta",
    "evidence_trace_ids"
  ],
  "additionalProperties": false,
  "properties": {
    "target_failure": {
      "type": "string",
      "description": "The recurring, evidenced failure this addresses."
    },
    "hypothesis": {
      "type": "string",
      "description": "A falsifiable claim: applying `delta` should reduce `target_failure` without regressions."
    },
    "kind": {
      "type": "string",
      "enum": [
        "lesson",
        "playbook"
      ],
      "description": "A heuristic (lesson) or a reusable task strategy (playbook). NEVER a capability or constraint change."
    },
    "target_role": {
      "type": "string"
    },
    "delta": {
      "type": "string",
      "description": "The proposed addition or summary of a structured playbook delta. Append-only in intent."
    },
    "playbook_delta": {
      "type": "object",
      "description": "Required when kind=playbook. A structured playbook addition or patch to be measured before ratification.",
      "required": ["change_type", "task_family"],
      "additionalProperties": false,
      "properties": {
        "playbook_id": { "type": "string" },
        "change_type": { "type": "string", "enum": ["add", "patch", "retire"] },
        "task_family": { "type": "string", "enum": ["github_push", "vercel_deploy", "supabase_migrate", "generic_workflow"] },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "fields_changed": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["aliases", "preflight_checks", "steps", "verification", "rollback_or_recovery", "known_issue_refs", "required_environment_bindings"]
          }
        },
        "rationale": { "type": "string" }
      }
    },
    "evidence_trace_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "measured_benefit": {
      "type": [
        "number",
        "null"
      ],
      "description": "Set by the Evaluator: failure-rate reduction on held-out historical traces."
    },
    "regressions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      },
      "description": "Set by the Evaluator: any new failures the change would introduce."
    },
    "evaluation_evidence": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": { "required": ["measured_benefit"] },
      "then": { "required": ["regressions", "evaluation_evidence"] }
    },
    {
      "if": { "required": ["evaluation_evidence"] },
      "then": { "required": ["measured_benefit", "regressions"] }
    },
    {
      "if": { "properties": { "kind": { "const": "playbook" } }, "required": ["kind"] },
      "then": { "required": ["playbook_delta"] }
    }
  ]
}
