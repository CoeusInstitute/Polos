{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocAssignmentPayload",
  "description": "Instruction for the Archivist to update specific docs.",
  "type": "object",
  "required": [
    "doc_assignment_id",
    "targets",
    "reason"
  ],
  "additionalProperties": false,
  "properties": {
    "doc_assignment_id": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    }
  }
}
