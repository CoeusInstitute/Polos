{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerdictPayload",
  "description": "A gate's decision, streamed to Security and the audit log.",
  "type": "object",
  "required": [
    "decision",
    "rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "axis_a_intent": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "n/a"
      ]
    },
    "axis_b_harm": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "n/a"
      ]
    },
    "rationale": {
      "type": "string"
    }
  }
}
