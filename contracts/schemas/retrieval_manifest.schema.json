{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RetrievalManifestPayload",
  "description": "Declarative spec of what the Retrieval Worker should fetch. Describes data, never actions.",
  "type": "object",
  "required": [
    "queries"
  ],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string"
    }
  }
}
