{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RejectedImprovementPayload",
  "description": "An improvement the Evaluator rejected (no measured benefit, or it introduced regressions). Logged for the record.",
  "type": "object",
  "required": [
    "improvement_ref",
    "reason"
  ],
  "additionalProperties": false,
  "properties": {
    "improvement_ref": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "measured_benefit": {
      "type": [
        "number",
        "null"
      ]
    },
    "regressions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}
