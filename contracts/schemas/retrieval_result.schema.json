{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RetrievalResultPayload",
  "description": "Read-only findings with per-item provenance; suspected injection flagged for the Monitor.",
  "type": "object",
  "required": [
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "content",
          "provenance"
        ],
        "additionalProperties": false,
        "properties": {
          "content": {
            "type": "string"
          },
          "provenance": {
            "type": "string"
          },
          "flagged_injection": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
