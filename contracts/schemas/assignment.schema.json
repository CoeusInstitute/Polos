{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssignmentPayload",
  "description": "A single unit of work. JIT credentials ride on the envelope's credentials field.",
  "type": "object",
  "required": [
    "assignment_id",
    "goal",
    "definition_of_done",
    "consequence_class"
  ],
  "additionalProperties": false,
  "properties": {
    "assignment_id": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "definition_of_done": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consequence_class": {
      "type": "string",
      "enum": [
        "read",
        "write-internal",
        "external-write",
        "comms",
        "financial",
        "code-exec",
        "docs"
      ]
    }
  }
}
