{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RepairManifestPayload",
  "description": "A Monitor-reviewed prescription for repairing harness drift through normal actors.",
  "type": "object",
  "required": [
    "repair_manifest_id",
    "checkup_ref",
    "trigger_ref",
    "scope",
    "repair_items",
    "consequence_ceiling",
    "requires_human",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "repair_manifest_id": { "type": "string" },
    "checkup_ref": { "type": "string" },
    "trigger_ref": { "type": "string" },
    "scope": {
      "type": "array",
      "items": { "type": "string", "enum": ["roles", "graph", "schemas", "config", "validator", "dox", "docs", "state-machine", "runtime-signals"] },
      "minItems": 1
    },
    "repair_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repair_item_id", "target_area", "target_paths", "issue", "proposed_action", "assigned_actor", "consequence_class", "definition_of_done"],
        "additionalProperties": false,
        "properties": {
          "repair_item_id": { "type": "string" },
          "target_area": { "type": "string", "enum": ["role", "graph", "schema", "config", "validator", "dox", "docs", "state-machine", "runtime-signal"] },
          "target_paths": { "type": "array", "items": { "type": "string" } },
          "issue": { "type": "string" },
          "proposed_action": { "type": "string" },
          "assigned_actor": { "type": "string", "enum": ["execution-worker", "archivist", "human"] },
          "consequence_class": { "type": "string", "enum": ["docs", "write-internal", "code-exec"] },
          "definition_of_done": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "requires_human": { "type": "boolean" }
        }
      }
    },
    "consequence_ceiling": { "type": "string", "enum": ["docs", "write-internal", "code-exec"] },
    "requires_human": { "type": "boolean" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocked_reasons": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}